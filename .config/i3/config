# current status bar
# Start i3bar to display a workspace bar (plus the system information i3status if available)

bar {
	i3bar_command i3bar
	status_command i3status
	position top
	#mode hide
	mode dock

## please set your primary output first. Example: 'xrandr --output eDP1 --primary'
#	tray_output primary
#	tray_output eDP1

	bindsym button4 nop
	bindsym button5 nop
	#font xft:URWGothic-Book 12
	#font xft:Awesome 13
	#font pango:DejaVu Sans Mono 10
	#font xft:TerminessTTFNerdFontMono 17
	strip_workspace_numbers yes

    colors {
        background #000000
        statusline #b6b6b6
        separator  #000000

#                           border  backgr. text
        focused_workspace  #000000 #000000 #a6000d
        active_workspace   #000000 #000000 #a6000d
        inactive_workspace #000000 #000000 #b6b6b6
        binding_mode       #16a085 #2C2C2C #F9FAF9
        urgent_workspace   #16a085 #FDF6E3 #E5201D
    }
}


